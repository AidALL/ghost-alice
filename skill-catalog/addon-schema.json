{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Ghost-ALICE Addon Manifest",
  "type": "object",
  "required": ["manifest_version", "addons"],
  "additionalProperties": false,
  "properties": {
    "manifest_version": {
      "type": "integer",
      "const": 1
    },
    "addons": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "path"],
        "additionalProperties": false,
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[a-z][a-z0-9-]*$"
          },
          "path": {
            "type": "string"
          },
          "min_core_version": {
            "type": "string"
          },
          "tags": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      }
    }
  }
}
